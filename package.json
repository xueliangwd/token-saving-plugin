{
  "name": "token-saving-plugin",
  "displayName": "%extension.displayName%",
  "description": "%extension.description%",
  "version": "0.0.7",
  "publisher": "local",
  "icon": "media/icon.png",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:promptOptimizer.run",
    "onCommand:promptOptimizer.setupWizard",
    "onCommand:promptOptimizer.sendToNewEditor",
    "onCommand:promptOptimizer.optimizeClipboardPaste",
    "onCommand:promptOptimizer.sendToCursorChat",
    "onCommand:promptOptimizer.quickCursorReplace",
    "onCommand:promptOptimizer.statusBarModels",
    "onCommand:promptOptimizer.copyMcpConfig",
    "onCommand:promptOptimizer.openMcpGuide",
    "onCommand:promptOptimizer.mcpInterceptPreview",
    "onCommand:promptOptimizer.quickFill.chatgpt",
    "onCommand:promptOptimizer.quickFill.codex",
    "onCommand:promptOptimizer.quickFill.claude",
    "onCommand:promptOptimizer.quickFill.gemini",
    "onCommand:promptOptimizer.quickFill.deepseek"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "promptOptimizer.run",
        "title": "%command.run.title%",
        "icon": "$(wand)"
      },
      {
        "command": "promptOptimizer.setupWizard",
        "title": "%command.setupWizard.title%",
        "icon": "$(gear)"
      },
      {
        "command": "promptOptimizer.sendToNewEditor",
        "title": "%command.sendToNewEditor.title%",
        "icon": "$(go-to-file)"
      },
      {
        "command": "promptOptimizer.optimizeClipboardPaste",
        "title": "%command.optimizeClipboardPaste.title%",
        "icon": "$(clippy)"
      },
      {
        "command": "promptOptimizer.sendToCursorChat",
        "title": "%command.sendToCursorChat.title%",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "promptOptimizer.quickCursorReplace",
        "title": "%command.quickCursorReplace.title%",
        "icon": "$(zap)"
      },
      {
        "command": "promptOptimizer.statusBarModels",
        "title": "%command.statusBarModels.title%",
        "icon": "$(symbol-color)"
      },
      {
        "command": "promptOptimizer.copyMcpConfig",
        "title": "%command.copyMcpConfig.title%",
        "icon": "$(server-environment)"
      },
      {
        "command": "promptOptimizer.openMcpGuide",
        "title": "%command.openMcpGuide.title%",
        "icon": "$(book)"
      },
      {
        "command": "promptOptimizer.mcpInterceptPreview",
        "title": "%command.mcpInterceptPreview.title%",
        "icon": "$(eye)"
      },
      {
        "command": "promptOptimizer.quickFill.chatgpt",
        "title": "%command.quickFillChatgpt.title%",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "promptOptimizer.quickFill.codex",
        "title": "%command.quickFillCodex.title%",
        "icon": "$(code)"
      },
      {
        "command": "promptOptimizer.quickFill.claude",
        "title": "%command.quickFillClaude.title%",
        "icon": "$(hubot)"
      },
      {
        "command": "promptOptimizer.quickFill.gemini",
        "title": "%command.quickFillGemini.title%",
        "icon": "$(sparkle)"
      },
      {
        "command": "promptOptimizer.quickFill.deepseek",
        "title": "%command.quickFillDeepseek.title%",
        "icon": "$(search-fuzzy)"
      }
    ],
    "submenus": [
      {
        "id": "promptOptimizer.modelsSubmenu",
        "label": "%submenu.models.label%"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "promptOptimizer.run",
          "when": "editorTextFocus",
          "group": "navigation@10"
        },
        {
          "command": "promptOptimizer.sendToNewEditor",
          "when": "editorTextFocus",
          "group": "navigation@11"
        },
        {
          "command": "promptOptimizer.sendToCursorChat",
          "when": "editorTextFocus",
          "group": "navigation@12"
        },
        {
          "command": "promptOptimizer.quickCursorReplace",
          "when": "editorHasSelection",
          "group": "navigation@13"
        },
        {
          "command": "promptOptimizer.quickFill.chatgpt",
          "when": "editorTextFocus",
          "group": "navigation@14"
        },
        {
          "command": "promptOptimizer.quickFill.claude",
          "when": "editorTextFocus",
          "group": "navigation@15"
        },
        {
          "command": "promptOptimizer.quickFill.gemini",
          "when": "editorTextFocus",
          "group": "navigation@16"
        },
        {
          "command": "promptOptimizer.quickFill.codex",
          "when": "editorTextFocus",
          "group": "navigation@17"
        },
        {
          "command": "promptOptimizer.quickFill.deepseek",
          "when": "editorTextFocus",
          "group": "navigation@18"
        }
      ],
      "editor/title": [
        {
          "command": "promptOptimizer.run",
          "when": "editorTextFocus",
          "group": "navigation@90"
        },
        {
          "command": "promptOptimizer.quickCursorReplace",
          "when": "editorHasSelection",
          "group": "navigation@91"
        },
        {
          "submenu": "promptOptimizer.modelsSubmenu",
          "when": "editorTextFocus",
          "group": "navigation@92"
        }
      ],
      "promptOptimizer.modelsSubmenu": [
        {
          "command": "promptOptimizer.quickFill.chatgpt",
          "group": "inline@1"
        },
        {
          "command": "promptOptimizer.quickFill.claude",
          "group": "inline@2"
        },
        {
          "command": "promptOptimizer.quickFill.gemini",
          "group": "inline@3"
        },
        {
          "command": "promptOptimizer.quickFill.codex",
          "group": "inline@4"
        },
        {
          "command": "promptOptimizer.quickFill.deepseek",
          "group": "inline@5"
        },
        {
          "command": "promptOptimizer.sendToCursorChat",
          "group": "inline@6"
        }
      ],
      "commandPalette": [
        {
          "command": "promptOptimizer.run"
        },
        {
          "command": "promptOptimizer.setupWizard"
        },
        {
          "command": "promptOptimizer.sendToNewEditor"
        },
        {
          "command": "promptOptimizer.optimizeClipboardPaste"
        },
        {
          "command": "promptOptimizer.sendToCursorChat"
        },
        {
          "command": "promptOptimizer.quickCursorReplace"
        },
        {
          "command": "promptOptimizer.quickFill.chatgpt"
        },
        {
          "command": "promptOptimizer.quickFill.codex"
        },
        {
          "command": "promptOptimizer.quickFill.claude"
        },
        {
          "command": "promptOptimizer.quickFill.gemini"
        },
        {
          "command": "promptOptimizer.quickFill.deepseek"
        },
        {
          "command": "promptOptimizer.copyMcpConfig"
        },
        {
          "command": "promptOptimizer.openMcpGuide"
        },
        {
          "command": "promptOptimizer.mcpInterceptPreview"
        }
      ],
      "editor/title/context": [
        {
          "command": "promptOptimizer.run",
          "when": "editorTextFocus",
          "group": "navigation@1"
        },
        {
          "command": "promptOptimizer.quickCursorReplace",
          "when": "editorHasSelection",
          "group": "navigation@2"
        }
      ]
    },
    "keybindings": [
      {
        "command": "promptOptimizer.run",
        "key": "ctrl+alt+p",
        "mac": "cmd+alt+p"
      },
      {
        "command": "promptOptimizer.sendToNewEditor",
        "key": "ctrl+alt+o",
        "mac": "cmd+alt+o"
      },
      {
        "command": "promptOptimizer.sendToCursorChat",
        "key": "ctrl+alt+l",
        "mac": "cmd+alt+l"
      },
      {
        "command": "promptOptimizer.quickCursorReplace",
        "key": "ctrl+alt+r",
        "mac": "cmd+alt+r"
      }
    ],
    "configuration": {
      "title": "%config.title%",
      "properties": {
        "promptOptimizer.defaultTargetModel": {
          "type": "string",
          "enum": [
            "chatgpt",
            "cursor",
            "codex",
            "claude",
            "gemini",
            "deepseek"
          ],
          "default": "cursor",
          "description": "%config.defaultTargetModel.description%"
        },
        "promptOptimizer.transformationEngine": {
          "type": "string",
          "enum": [
            "local",
            "remote"
          ],
          "default": "local",
          "description": "%config.transformationEngine.description%"
        },
        "promptOptimizer.outputLanguage": {
          "type": "string",
          "enum": [
            "english",
            "source"
          ],
          "default": "english",
          "description": "%config.outputLanguage.description%"
        },
        "promptOptimizer.remote.provider": {
          "type": "string",
          "enum": [
            "ollama",
            "openai-compatible"
          ],
          "default": "ollama",
          "description": "%config.remoteProvider.description%"
        },
        "promptOptimizer.remote.baseUrl": {
          "type": "string",
          "default": "http://127.0.0.1:11434/v1",
          "description": "%config.remoteBaseUrl.description%"
        },
        "promptOptimizer.remote.apiKey": {
          "type": "string",
          "default": "",
          "markdownDescription": "%config.remoteApiKey.description%"
        },
        "promptOptimizer.remote.model": {
          "type": "string",
          "default": "qwen2.5:3b-instruct",
          "description": "%config.remoteModel.description%"
        },
        "promptOptimizer.remote.temperature": {
          "type": "number",
          "default": 0.2,
          "minimum": 0,
          "maximum": 1,
          "description": "%config.remoteTemperature.description%"
        },
        "promptOptimizer.remote.timeoutMs": {
          "type": "number",
          "default": 30000,
          "minimum": 1000,
          "description": "%config.remoteTimeoutMs.description%"
        },
        "promptOptimizer.remote.systemPrompt": {
          "type": "string",
          "default": "",
          "description": "%config.remoteSystemPrompt.description%"
        },
        "promptOptimizer.remote.fallbackToLocal": {
          "type": "boolean",
          "default": true,
          "description": "%config.remoteFallbackToLocal.description%"
        },
        "promptOptimizer.clipboard.autoPasteToActiveEditor": {
          "type": "boolean",
          "default": true,
          "description": "%config.clipboardAutoPaste.description%"
        },
        "promptOptimizer.cursorChat.openAfterCopy": {
          "type": "boolean",
          "default": true,
          "description": "%config.cursorChatOpenAfterCopy.description%"
        },
        "promptOptimizer.selectionAutoOptimize.enabled": {
          "type": "boolean",
          "default": false,
          "description": "%config.selectionAutoOptimizeEnabled.description%"
        },
        "promptOptimizer.selectionAutoOptimize.debounceMs": {
          "type": "number",
          "default": 600,
          "minimum": 150,
          "description": "%config.selectionAutoOptimizeDebounce.description%"
        },
        "promptOptimizer.onboarding.showOnStartup": {
          "type": "boolean",
          "default": true,
          "description": "%config.onboardingShowOnStartup.description%"
        },
        "promptOptimizer.commonRules.enabled": {
          "type": "boolean",
          "default": true,
          "description": "%config.commonRulesEnabled.description%"
        },
        "promptOptimizer.commonRules.appendBuiltIn": {
          "type": "boolean",
          "default": true,
          "description": "%config.commonRulesAppendBuiltIn.description%"
        },
        "promptOptimizer.commonRules.customRules": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "%config.commonRulesCustomRules.description%"
        },
        "promptOptimizer.mcp.defaultTargetModel": {
          "type": "string",
          "enum": [
            "chatgpt",
            "cursor",
            "codex",
            "claude",
            "gemini",
            "deepseek"
          ],
          "default": "cursor",
          "description": "%config.mcpDefaultTargetModel.description%"
        },
        "promptOptimizer.mcp.previewBeforeSend": {
          "type": "boolean",
          "default": true,
          "description": "%config.mcpPreviewBeforeSend.description%"
        },
        "promptOptimizer.mcp.autoSend": {
          "type": "boolean",
          "default": false,
          "description": "%config.mcpAutoSend.description%"
        }
      }
    }
  },
  "scripts": {
    "build": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "smoke-test": "node ./scripts/smoke-test.js",
    "unit-test": "node ./scripts/unit-test.js",
    "package-vsix": "node ./scripts/package-vsix.js"
  },
  "devDependencies": {
    "@types/node": "^22.13.11",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.8.2"
  }
}
